{"_default": {"1": {"question": "\u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09b0\u09be\u099c\u09a7\u09be\u09a8\u09c0\u09b0 \u09a8\u09be\u09ae \u0995\u09bf ", "answer": "\u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09b0\u09be\u099c\u09a7\u09be\u09a8\u09c0\u09b0 \u09a8\u09be\u09ae \u09a2\u09be\u0995\u09be "}, "2": {"question": "\u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09ac\u09b0\u09cd\u09a4\u09ae\u09be\u09a8 \u099c\u09c7\u09b2\u09be \u0995\u09a4\u099f\u09bf", "answer": "\u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09ac\u09b0\u09cd\u09a4\u09ae\u09be\u09a8 \u099c\u09c7\u09b2\u09be \u09b8\u0982\u0996\u09cd\u09af\u09be \u09ec\u09ea \u099f\u09bf \u0964"}}}